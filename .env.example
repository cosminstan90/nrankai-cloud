# ── Required ──────────────────────────────────────────────────────────────────
# Public base URL of this service (no trailing slash)
BASE_URL=https://api.nrankai.com

# API key for n8n (generate a long random string, keep secret)
N8N_API_KEY=change_me_n8n_long_random_string

# API key for the local worker (different key, same format)
WORKER_API_KEY=change_me_worker_long_random_string

# Shared secret embedded in webhooks sent to n8n
# n8n validates X-Cloud-Secret header against this value
CLOUD_WEBHOOK_SECRET=change_me_webhook_secret

# ── Optional ──────────────────────────────────────────────────────────────────
# Port (default: 8080)
# PORT=8080

# Log level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

# Show API docs at /api/docs (disable in production)
# SHOW_DOCS=false

# Comma-separated list of allowed CORS origins (defaults to nrankai.com subdomains)
# ALLOWED_ORIGINS=https://nrankai.com,https://www.nrankai.com,https://api.nrankai.com,https://app.nrankai.com

# ── Worker (geo_tool on local machine) ───────────────────────────────────────
# Generate a separate key for the geo_tool worker
# WORKER_API_KEY=change_me_worker_long_random_string

# ── Email (Brevo SMTP — configured in n8n, not here) ─────────────────────────
# 1. Sign up free at brevo.com (300 emails/day, no card required)
# 2. Senders & IP → Domains → add nrankai.com → add SPF/DKIM DNS records
# 3. SMTP & API → Generate SMTP key
# 4. In n8n → Credentials → New → SMTP:
#      Name:     Brevo nrankai
#      Host:     smtp-relay.brevo.com
#      Port:     587
#      User:     <your Brevo login email>
#      Password: <the SMTP key, NOT your account password>
# 5. Note the credential ID → replace REPLACE_WITH_NRANKAI_SMTP_CREDENTIAL_ID
#    in all 3 workflow JSON files before importing
